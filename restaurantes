DROP TABLE IF EXISTS clientes;
DROP TABLE IF EXISTS restaurantes;
DROP TABLE IF EXISTS pedidos;
DROP TABLE IF EXISTS entregadores;
DROP TABLE IF EXISTS formas_pagamento;

CREATE TABLE clientes (
	id_clientes INTEGER PRIMARY KEY AUTOINCREMENT,
  	nome VARCHAR(100) NOT NULL,
  	telefone VARCHAR (9) NOT NULL
);

CREATE TABLE restaurantes (
  id_restaurantes INTEGER PRIMARY KEY AUTOINCREMENT,
  nome VARCHAR (150) NOT NULL,
  categoria VARCHAR (150) not NULL
);

CREATE TABLE entregadores (
  id_entregador INTEGER PRIMARY KEY AUTOINCREMENT,
  nome VARCHAR (150) NOT NULL,
  telefone VARCHAR (9) NOT NULL,
  veiculo VARCHAR (50) not NULL
);

CREATE TABLE formas_pagamento (
  id_pagamento INTEGER PRIMARY KEY AUTOINCREMENT,
  tipo_pagamento VARCHAR (50) not NULL
  );
  
create table pedidos (
  id_clientes INT,
  id_restaurantes INT,
  id_entregador INT,
  id_pagamento INT,
  valor_total REAL,
  data_pedido DATE,
  
  FOREIGN KEY (id_clientes) REFERENCES clientes(id_clientes),
  FOREIGN KEY (id_restaurantes) REFERENCES restaurantes(id_restaurantes),
  FOREIGN key (id_pagamento) REFERENCES formas_pagamento(id_pagamento),
  FOREIGN KEY (id_entregador) REFERENCES entregadores(id_entregador)
);
